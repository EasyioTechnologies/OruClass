{
  "name": "@oruclass/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "lint": "eslint src/",
    "test": "bun test",
    "type-check": "tsc --noEmit",
    "migrate": "bun run drizzle-kit migrate",
    "db:generate": "bun run drizzle-kit generate",
    "db:push": "bun run drizzle-kit push",
    "db:studio": "bun run drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@oruclass/types": "workspace:*",
    "@oruclass/utils": "workspace:*",
    "@oruclass/validators": "workspace:*",
    "@socket.io/redis-adapter": "^8.3.0",
    "bullmq": "^5.13.0",
    "drizzle-orm": "^0.38.0",
    "exceljs": "^4.4.0",
    "hono": "^4.6.0",
    "jose": "^6.2.3",
    "nanoid": "^5.1.11",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "redis": "^4.7.0",
    "resend": "^4.0.0",
    "socket.io": "^4.8.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "@types/bun": "latest",
    "typescript": "^5.7.2"
  }
}
