{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@oruclass/types": ["./packages/types/src/index.ts"],
      "@oruclass/validators": ["./packages/validators/src/index.ts"],
      "@oruclass/utils": ["./packages/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "**/node_modules", "**/.next", "**/dist"]
}
