# Database (Docker maps to 5433 locally to avoid conflict with native postgres)
DATABASE_URL=postgresql://oruclass:oruclass_dev_secret@localhost:5433/oruclass

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=change-me-in-production-min-64-chars

# Better Auth
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:3001

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID → Web application
# Authorized redirect URIs: http://localhost:3001/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# API / Web URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
# Production only: set to your public domain so QR codes encode the right URL.
# In development the LAN IP is auto-detected — no config needed.
# NEXT_PUBLIC_WEB_URL=https://yourdomain.com

# Email — https://resend.com/api-keys
RESEND_API_KEY=

# Cloudflare R2 — https://dash.cloudflare.com → R2 → Manage API Tokens
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=oruclass
R2_PUBLIC_URL=https://<bucket-public-domain>/oruclass
